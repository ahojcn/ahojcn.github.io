 j3=1;j3&lt;=5;j3++)</span><br><span class=\"line\">                        &#123;</span><br><span class=\"line\">                            if(a[j2][j3]==1)</span><br><span class=\"line\">                                a1[i5][j3]=1;</span><br><span class=\"line\">                            else</span><br><span class=\"line\">                            &#123;</span><br><span class=\"line\">                                for(int j4=1;j4&lt;=5;j4++)</span><br><span class=\"line\">                                &#123;</span><br><span class=\"line\">                                if(a[j3][j4]==1)</span><br><span class=\"line\">                                    a1[i5][j4]=1;</span><br><span class=\"line\">                                &#125;</span><br><span class=\"line\">                            &#125;</span><br><span class=\"line\">                        &#125;</span><br><span class=\"line\">                    &#125;</span><br><span class=\"line\">                &#125;</span><br><span class=\"line\">            &#125;</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">    &#125;</span><br><span class=\"line\">    printf(&quot;D的可达矩阵:\\n&quot;);</span><br><span class=\"line\">    for(int t1=1;t1&lt;=5;t1++)</span><br><span class=\"line\">    &#123;</span><br><span class=\"line\">        for(int t2=1;t2&lt;=5;t2++)</span><br><span class=\"line\">        &#123;</span><br><span class=\"line\">        printf(&quot;%d &quot;,a1[t1][t2]);</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">        printf(&quot;\\n&quot;);</span><br><span class=\"line\">    &#125;</span><br><span class=\"line\"></span><br><span class=\"line\">    return 0;</span><br><span class=\"line\">&#125;</span><br></pre></td></tr></table></figure>\n<h1 id=\"第二种做法\"><a href=\"#第二种做法\" class=\"headerlink\" title=\"第二种做法\"></a>第二种做法</h1><blockquote>\n<p>第二种实现方法，非常简单啦。</p>\n<blockquote>\n<p><img src=\"https://wx4.sinaimg.cn/mw690/006wR0dcly1